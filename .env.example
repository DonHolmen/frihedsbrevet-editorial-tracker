# --- Payload core ---
PAYLOAD_SECRET=dev-secret-change-me
# SQLite (libsql) — file-based, zero infra. Resolves relative to project root.
DATABASE_URI=file:./frihedsbrevet.db

# --- Realtime (Upstash Realtime — @upstash/realtime) ---
# REST endpoint + token only. The SDK is 100% HTTP (Redis Streams + SSE), so no
# native TLS/rediss:// endpoint is needed anymore.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token

# When these are absent the app still runs — realtime + presence become no-ops
# and the board falls back to local state only (see src/lib/redis.ts).
